# Supabase project credentials (Project Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Canonical site URL (no trailing slash) — used for SEO canonical/OG tags
# and sitemap generation. Set per-environment in Vercel:
#   production -> https://hkgrowinfra.com
#   preview    -> the Vercel preview URL or a staging domain
VITE_SITE_URL=https://hkgrowinfra.com

# Google Analytics 4 measurement ID (optional)
VITE_GA4_ID=G-XXXXXXXXXX

# WhatsApp number in international format, no '+' or spaces (optional)
VITE_WHATSAPP_NUMBER=919876543210
